# Runtime environment: local | railway
ENVIRONMENT=local

# Comma-separated list of origins allowed to call this API.
# In Railway, set this to your deployed frontend URL, e.g. https://fischer-chess.up.railway.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Reserved for future phases (model checkpoint path, Stockfish binary path, etc.)
MODEL_CHECKPOINT_PATH=./checkpoints/fischer_bc_v1.pt
STOCKFISH_PATH=/usr/games/stockfish
